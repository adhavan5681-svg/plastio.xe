# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ===========================================
# DATABASE (PostgreSQL - Supabase or AWS RDS)
# ===========================================
# For Supabase: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# For AWS RDS: postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DATABASE]
# ⚠️ URL-encode special characters in your password if any:
#    @ → %40   # → %23   $ → %24   % → %25
# Example with password containing @: postgresql://postgres:%40Adhav026an@host:5432/postgres
DATABASE_URL="postgresql://username:password@host:5432/database"

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# For local development
NEXTAUTH_URL="http://localhost:3000"

# For production (Amplify) - will be your Amplify app URL
# NEXTAUTH_URL="https://your-app.amplifyapp.com"

# ===========================================
# SUPABASE STORAGE (for photo uploads)
# ===========================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ===========================================
# OPTIONAL: AWS CONFIGURATION (if using AWS services)
# ===========================================
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# S3_BUCKET_NAME="your-bucket-name"
